# ============================================
# ChamaLead - Configuração Externa
# ============================================

# Modo de operação (prod/staging)
MODE=prod

# URL base da API
BASE_URL=http://localhost:5678
WEBHOOK_PATH=/webhook/cc255ec8-1dcd-4279-9e73-5288ea4df2f1

# Instâncias ativas (separadas por vírgula)
INSTANCES=CHAMALEAD_PROSPECT,hype_lima_testeeee

# Limites anti-ban
MAX_PER_RUN=30
DAILY_LIMIT=60
DAILY_LIMIT_PER_INSTANCE=30
DELAY_MIN=120
DELAY_MAX=240
BATCH_SIZE=10
BATCH_PAUSE=300

# Horário proibido (21:00-23:00)
FORBIDDEN_START=21
FORBIDDEN_END=23

# Backoff e pausas
ERROR_BACKOFF=600
IDLE_PAUSE=60
